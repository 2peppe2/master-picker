model Course {
  code      String
  programCourseID Int
  credits   Int
  level     String
  name      String
  link      String
  examiner  String
  ecv       String
  prerequisitesText   String
  scheduledHours      Int
  selfStudyHours     Int
  updatedAt DateTime @default(now())
  
  // Relationship mappings.
  Examination         Examination[]
  CourseMaster        CourseMaster[]
  CourseOccasion      CourseOccasion[]
  CoursesRequirements CourseRequirementCourse[]

  ProgramCourse ProgramCourse @relation (fields: [programCourseID], references: [id], onDelete: Cascade)

  @@id([code, programCourseID])
}
