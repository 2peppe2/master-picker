model Requirement {
  id              Int           @id @default(autoincrement())
  masterProgram   String
  program         String
  programCourseID Int
  programCourse   ProgramCourse @relation(fields: [programCourseID], references: [id], onDelete: Cascade)
  master          Master        @relation(fields: [masterProgram, program], references: [master, masterProgram], onDelete: Cascade)

  creditRequirements    CreditRequirement[]
  courseRequirements    CoursesRequirement[]
  mainFieldRequirements MainFieldRequirement[]
}
